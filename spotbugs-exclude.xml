<FindBugsFilter>
    <!--
      SwaggerPackCompilerPlugin creates a single OpenApiDocumentStore per compilation and hands
      the same live reference to SwaggerPackCodeAnalyzer/SwaggerPackCollectTask (which populate
      it while the semantic model is valid) and SwaggerPackLifecycleListener/SwaggerPackLifecycleTask
      (which read it once the JAR exists, when the semantic model is not). Sharing the reference
      is required, not incidental, so EI_EXPOSE_REP2 here is a false positive.
    -->
    <Match>
        <Class name="io.ballerina.lib.wso2.icp.compiler.SwaggerPackCodeAnalyzer"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Class name="io.ballerina.lib.wso2.icp.compiler.SwaggerPackCollectTask"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Class name="io.ballerina.lib.wso2.icp.compiler.SwaggerPackLifecycleListener"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Class name="io.ballerina.lib.wso2.icp.compiler.SwaggerPackLifecycleTask"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
</FindBugsFilter>
